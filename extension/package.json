    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "marked": "18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/chrome": "0.1.40",
    "esbuild": "0.28.0",
    "typescript": "6.0.2"
  }
}
